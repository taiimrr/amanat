{
  "name": "amanat",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "dev:api": "bun run --cwd packages/api dev",
    "dev:web": "bun run --cwd packages/web dev",
    "build": "bun run --cwd packages/api build && bun run --cwd packages/web build",
    "test": "bun run --cwd packages/api test",
    "db:migrate": "bun run --cwd packages/api db:migrate",
    "db:seed": "bun run --cwd packages/api db:seed",
    "db:studio": "bun run --cwd packages/api db:studio"
  }
}
