{
  "name": "amanat",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "dev:api": "bun --cwd packages/api run dev",
    "dev:web": "bun --cwd packages/web run dev",
    "build": "bun --cwd packages/api run build && bun --cwd packages/web run build",
    "test": "bun --cwd packages/api run test",
    "db:migrate": "bun --cwd packages/api run db:migrate",
    "db:seed": "bun --cwd packages/api run db:seed",
    "db:studio": "bun --cwd packages/api run db:studio"
  }
}
